{
  "deployment": {
    "platform": "cPanel",
    "nodeVersion": "20.11.0",
    "runtime": "Node.js",
    "framework": "Next.js",
    "database": "PostgreSQL",
    "serverFile": "server.js",
    "buildCommand": "npm run build",
    "startCommand": "node server.js",
    "installCommand": "npm install --production"
  },
  "requirements": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0",
    "postgresql": ">=12.0"
  },
  "environment": {
    "required": [
      "DATABASE_URL",
      "NEXTAUTH_URL",
      "NEXTAUTH_SECRET",
      "NODE_ENV"
    ],
    "optional": [
      "EMAIL_SERVER",
      "EMAIL_FROM",
      "MAX_FILE_SIZE",
      "UPLOAD_DIR"
    ]
  },
  "paths": {
    "applicationRoot": "/home/username/kevincab",
    "startupFile": "server.js",
    "buildOutput": ".next",
    "publicAssets": "public",
    "logs": "logs"
  },
  "features": {
    "ssl": true,
    "compression": true,
    "caching": true,
    "gitDeployment": true,
    "autoRestart": true
  }
}
